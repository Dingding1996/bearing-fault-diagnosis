# =============================================================
# Files excluded from Docker build context
# Keeps the image small and avoids copying sensitive/large files
# =============================================================

# Dataset (large — mount as volume instead)
paderborn_data/
data/

# MLflow artefacts
# mlruns/ is intentionally NOT ignored — CI downloads it from S3 before building
# so it gets baked into the image. Local dev uses docker-compose volume mount instead.
mlflow.db

# Notebooks and training-only files
*.ipynb
*.ipynb_checkpoints/
plots/
*.pkl

# Python build artefacts
__pycache__/
*.py[cod]
*.pyo

# Git and tooling
.git/
.gitignore
.claude/
CLAUDE.md

# Credentials
.env
.kaggle/
kaggle.json

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Docs
*.pdf
README.md
